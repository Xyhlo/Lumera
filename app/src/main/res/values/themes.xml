<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Lumera" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <!-- Dark window background to eliminate white flash on cold start -->
        <item name="android:windowBackground">@android:color/black</item>
        <!-- Enable hardware acceleration for faster first frame -->
        <item name="android:hardwareAccelerated">true</item>
    </style>
</resources>